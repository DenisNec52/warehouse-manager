# ══════════════════════════════════════════════
#  Warehouse Pro — Backend ENV
# ══════════════════════════════════════════════

PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/warehouse?retryWrites=true&w=majority

# JWT — genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=SOSTITUISCI_CON_64_CARATTERI_CASUALI
JWT_EXPIRES_IN=7d

# Cookie
COOKIE_SECURE=false        # true in produzione (HTTPS)

# CORS — URL frontend senza slash finale
FRONTEND_URL=http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000   # 15 minuti
RATE_LIMIT_MAX=200
RATE_LIMIT_LOGIN_MAX=10

# MailerSend (opzionale — metti false per disabilitare)
ENABLE_EMAIL=false
MAILERSEND_API_KEY=mlsn.xxxx
MAIL_FROM=noreply@tuodominio.com
MAIL_FROM_NAME=Warehouse Pro
MAIL_ADMIN=tua@email.com

# Seed admin iniziale
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=Admin123!
SEED_ADMIN_NAME=Amministratore

# Cloudinary (struttura pronta, non ancora usata)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
